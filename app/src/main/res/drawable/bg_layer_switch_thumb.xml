<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <size
                android:width="24dp"
                android:height="24dp" />
            <corners android:radius="12dp" />
            <solid android:color="@color/safelayer_switch_thumb" />
            <stroke
                android:width="1dp"
                android:color="@color/safelayer_tab_pressed" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <size
                android:width="24dp"
                android:height="24dp" />
            <corners android:radius="12dp" />
            <solid android:color="@color/safelayer_switch_thumb" />
            <stroke
                android:width="1dp"
                android:color="@color/safelayer_tab_stroke" />
        </shape>
    </item>
</selector>
