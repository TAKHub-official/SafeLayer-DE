<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="@color/safelayer_tab_pressed" />
            <stroke
                android:width="1dp"
                android:color="@color/safelayer_tab_stroke" />
        </shape>
    </item>

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="@color/safelayer_tab_active" />
            <stroke
                android:width="1dp"
                android:color="@color/safelayer_tab_stroke" />
        </shape>
    </item>

    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="@color/safelayer_tab_active" />
            <stroke
                android:width="1dp"
                android:color="@color/safelayer_tab_stroke" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="@color/safelayer_tab_inactive" />
            <stroke
                android:width="1dp"
                android:color="@color/safelayer_tab_stroke" />
        </shape>
    </item>
</selector>
